#!/bin/sh
# hermes-os — wrapper for the in-repo copy (repo/scripts/hermes-os).
# The installed copy in ~/.local/bin is generated by install_termux.sh
# with the repo path baked in; this one resolves it relative to itself.
# hermes-android-agentic-os wrapper v1
set -eu

SCRIPT="$0"
# Resolve symlinks portably (readlink -f is not guaranteed on Android).
while [ -h "$SCRIPT" ]; do
  DIR=$(cd "$(dirname "$SCRIPT")" && pwd)
  SCRIPT=$(readlink "$SCRIPT")
  case "$SCRIPT" in /*) ;; *) SCRIPT="$DIR/$SCRIPT" ;; esac
done
REPO_DIR=$(cd "$(dirname "$SCRIPT")/.." && pwd)

PY=python3
command -v python3 >/dev/null 2>&1 || PY=python

PYTHONPATH="$REPO_DIR${PYTHONPATH:+:$PYTHONPATH}" exec "$PY" -m hermes_os.cli "$@"
