<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widgetRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="#1c1510">

    <TextView
        android:id="@+id/widgetTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Hermes OS"
        android:textColor="#ffb454"
        android:textStyle="bold"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/widgetStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Gateway · Cron · Risks: OK"
        android:textColor="#e9dcc3"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/widgetHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Tap to open dashboard"
        android:textColor="#9a8768"
        android:textSize="11sp" />
</LinearLayout>
